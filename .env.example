# ============================================
# Nootro Affiliate Leaderboard Bot - Config
# ============================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord OAuth2 (for Linked Roles / NTRO badge)
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_CLIENT_SECRET=your_oauth2_client_secret_here
DISCORD_REDIRECT_URI=https://your-railway-url.up.railway.app/discord-oauth-callback

# Discord Channel ID for #affiliate-leaderboard
LEADERBOARD_CHANNEL_ID=your_channel_id_here

# Google Sheets Config
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Data Source: "sheets" or "tiktok_api" (switch when API is approved)
DATA_SOURCE=sheets

# TikTok Shop API (for later - leave blank for now)
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# Cron schedule for daily post (default: 9:00 AM EST)
CRON_SCHEDULE=0 9 * * *

# Timezone
TZ=America/New_York
